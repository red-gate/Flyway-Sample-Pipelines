# =============================================================================
# Local Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# startup-services.ps1 reads these to create Docker containers.
# generate_pipeline.py also reads .env when running locally.
#
# In GitLab CI/CD, set variables in Settings → CI/CD → Variables instead.
# =============================================================================

# ── Docker Network (gitlab-net 172.30.0.0/24) ──────────────────────────────
#   Rancher:       172.30.0.10  →  host ports 80 / 443
#   GitLab:        172.30.0.2   →  host ports 8080 / 8443 / 2222
#   GitLab Runner: 172.30.0.3   →  (no host ports)
#   SQL Server:    172.30.0.4   →  host port 1434


# ═══════════════════════════════════════════════════════════════════════════
# 1. INFRASTRUCTURE  (used by startup-services.ps1)
# ═══════════════════════════════════════════════════════════════════════════

# ── Rancher ──
RANCHER_BOOTSTRAP_PASSWORD=your_rancher_password

# ── GitLab ──
GITLAB_ROOT_PASSWORD=your_gitlab_root_password
GITLAB_RUNNER_REGISTRATION_TOKEN=your_runner_registration_token
GITLAB_URL=http://172.30.0.2
GITLAB_EXTERNAL_URL=http://localhost:8080

# ── SQL Server — Prod (local SQLEXPRESS) ──
# Your existing SQL Express instance. Containers reach it via host.docker.internal.
SQL_HOST=host.docker.internal
SQL_PORT=1433
SQL_USER=sa
SQL_PASSWORD=your_sql_password

# ── SQL Server — QA (Docker container on gitlab-net) ──
# Second SQL Server for QA targets and QA registry. SSMS: localhost,1434
SQL2_HOST=172.30.0.4
SQL2_PORT=1434
SQL2_SA_PASSWORD=your_qa_sql_password


# ═══════════════════════════════════════════════════════════════════════════
# 2. FLYWAY PIPELINE  (used by generate_pipeline.py and CI/CD jobs)
# ═══════════════════════════════════════════════════════════════════════════
#
# The pipeline generator connects to a flyway_registry database to discover
# deployment targets. QA and Prod each have their own registry on separate
# SQL Servers. The staging-and-production pipeline passes these as
# REGISTRY_* overrides per stage.
#
# ┌─────────────────────────────────────────────────────────────────────┐
# │  CI/CD Variable              │ Required │ Where to set             │
# ├─────────────────────────────────────────────────────────────────────┤
# │  TARGET_DATABASE_USER        │ Yes      │ GitLab CI/CD Variables   │
# │  TARGET_DATABASE_PASSWORD    │ Yes      │ GitLab CI/CD (masked)    │
# │  QA_REGISTRY_SERVER          │ Yes      │ GitLab CI/CD Variables   │
# │  QA_REGISTRY_USER            │ Yes      │ GitLab CI/CD Variables   │
# │  QA_REGISTRY_PASSWORD        │ Yes      │ GitLab CI/CD (masked)    │
# │  PROD_REGISTRY_SERVER        │ Yes      │ GitLab CI/CD Variables   │
# │  PROD_REGISTRY_USER          │ Yes      │ GitLab CI/CD Variables   │
# │  PROD_REGISTRY_PASSWORD      │ Yes      │ GitLab CI/CD (masked)    │
# │  FLYWAY_EMAIL                │ Yes      │ GitLab CI/CD Variables   │
# │  FLYWAY_TOKEN                │ Yes      │ GitLab CI/CD (masked)    │
# │                              │          │                          │
# │  TARGET_DATABASE_JDBC        │ Schema*  │ GitLab CI/CD Variables   │
# │  SHADOW_DATABASE_JDBC        │ Schema*  │ GitLab CI/CD Variables   │
# │  SHADOW_DATABASE_USER        │ No       │ defaults to TARGET_*     │
# │  SHADOW_DATABASE_PASSWORD    │ No       │ defaults to TARGET_*     │
# │  QA_REGISTRY_DATABASE        │ No       │ default: flyway_registry │
# │  QA_REGISTRY_PORT            │ No       │ default: 1433            │
# │  PROD_REGISTRY_DATABASE      │ No       │ default: flyway_registry │
# │  PROD_REGISTRY_PORT          │ No       │ default: 1433            │
# │  JDBC_PORT                   │ No       │ default: 1433            │
# │  FILTER_LOCATION             │ No       │ default: all             │
# │  INCLUDE_REPLICAS            │ No       │ default: false           │
# │  FLYWAY_LOCATIONS            │ No       │ default: filesystem:./m… │
# │  RUNNER_TAG_MAP              │ No       │ JSON: {"London":"tag1"}  │
# │  RUNNER_TAG_DEFAULT          │ No       │ single tag for all jobs  │
# │  TEMPLATE_PROJECT            │ No       │ default: root/templati…  │
# │  TEMPLATE_REF                │ No       │ default: main            │
# │  GIT_PUSH_TOKEN              │ Schema*  │ if CI_JOB_TOKEN can't…   │
# │  GENERATE_DESCRIPTION        │ No       │ default: AutoGenerated   │
# │  GENERATE_TYPES              │ No       │ default: versioned,undo  │
# │  GITLAB_EXTERNAL_URL         │ No       │ default: CI_SERVER_URL   │
# │                              │          │                          │
# │  * = required only for schema-model workflow                       │
# └─────────────────────────────────────────────────────────────────────┘

# ── QA Registry (Docker SQL Server — 172.30.0.4) ──
QA_REGISTRY_SERVER=172.30.0.4
QA_REGISTRY_PORT=1433
QA_REGISTRY_USER=sa
QA_REGISTRY_PASSWORD=your_qa_sql_password
QA_REGISTRY_DATABASE=flyway_registry

# ── Prod Registry (local SQLEXPRESS — host.docker.internal) ──
PROD_REGISTRY_SERVER=host.docker.internal
PROD_REGISTRY_PORT=1433
PROD_REGISTRY_USER=sa
PROD_REGISTRY_PASSWORD=your_sql_password
PROD_REGISTRY_DATABASE=flyway_registry

# ── Legacy single-registry vars (used by generate_pipeline.py default) ──
# When running the simple single-environment pipeline or testing locally.
REGISTRY_SERVER=172.30.0.4
REGISTRY_PORT=1433
REGISTRY_USER=sa
REGISTRY_PASSWORD=your_qa_sql_password
REGISTRY_DATABASE=flyway_registry


# ═══════════════════════════════════════════════════════════════════════════
# 3. FLYWAY LICENSING
# ═══════════════════════════════════════════════════════════════════════════

# Flyway Enterprise licensing (Personal Access Token)
# See: https://documentation.red-gate.com/fd/licensing-164167730.html
FLYWAY_EMAIL=your_email@example.com
FLYWAY_TOKEN=your_flyway_personal_access_token
