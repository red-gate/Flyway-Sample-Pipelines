# =============================================================================
# Startup Services
# =============================================================================

# Rancher
RANCHER_BOOTSTRAP_PASSWORD=admin

# SQL Server (used by startup-services.ps1)
SQL_SA_PASSWORD=Flyway2026!Secure

# Flyway Docker image used by Harness pipelines
FLYWAY_DOCKER_IMAGE=redgate/flyway:latest

# =============================================================================
# Flyway Pipeline Variables
# Set these as secrets in Harness UI (repo Settings > Secrets)
# =============================================================================

# Target database (single DB deployment)
# FLYWAY_URL=jdbc:sqlserver://172.31.0.4:1433;databaseName=Northwind;encrypt=false;trustServerCertificate=true
# FLYWAY_USER=sa
# FLYWAY_PASSWORD=Flyway2026!Secure

# Source/Shadow databases (script generation)
# SOURCE_DATABASE_JDBC=jdbc:sqlserver://172.31.0.4:1433;databaseName=Northwind;encrypt=false;trustServerCertificate=true
# SOURCE_DATABASE_USER=sa
# SOURCE_DATABASE_PASSWORD=Flyway2026!Secure
# SHADOW_DATABASE_JDBC=jdbc:sqlserver://172.31.0.4:1433;databaseName=Northwind_shadow;encrypt=false;trustServerCertificate=true

# Target database (for migrate after generation)
# TARGET_DATABASE_JDBC=jdbc:sqlserver://172.31.0.4:1433;databaseName=Northwind;encrypt=false;trustServerCertificate=true
# TARGET_DATABASE_USER=sa
# TARGET_DATABASE_PASSWORD=Flyway2026!Secure

# Flyway licensing
# FLYWAY_EMAIL=your@email.com
# FLYWAY_TOKEN=your-flyway-token

# Git push credentials (for committing generated scripts)
# GIT_PUSH_USER=your-harness-username
# GIT_PUSH_TOKEN=your-harness-pat
# HARNESS_URL=http://172.31.0.2:3000

# =============================================================================
# Registry-Driven Deployment (multi-database)
# =============================================================================

# REGISTRY_SERVER=172.31.0.4
# REGISTRY_PORT=1433
# REGISTRY_DATABASE=flyway_registry
# REGISTRY_USER=sa
# REGISTRY_PASSWORD=Flyway2026!Secure
# FILTER_LOCATION=all
# INCLUDE_REPLICAS=false
# JDBC_PORT=1433
